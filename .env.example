# Copy to .env and fill in values.
# Config order:
# 1) Required wallet/base bot settings
# 2) BTC 5m common settings shared by live strategies
# 3) Strategy-specific settings
# 4) Research tools: backtest and collector

# =============================================================================
# 1. Required wallet / Polymarket base config
# =============================================================================

WALLET_PRIVATE_KEY=

# Wallet signature type: eoa | proxy | gnosis
SIG_TYPE=eoa
PROXY_WALLET_ADDRESS=

# General Polymarket / Polygon defaults
# DEBUG=false
# CHAIN_ID=137
# CLOB_API_URL=https://clob.polymarket.com
# NEG_RISK=false
# Set true only if USDC allowance has already been approved.
# Otherwise the bot needs a small amount of POL/MATIC gas to approve allowance.
SKIP_ALLOWANCE_APPROVE=false

# Balance gate used by live trading scripts
# BOT_MIN_USDC_BALANCE=1

# Logging
# LOG_DIR=logs
# LOG_FILE_PREFIX=bot
# LOG_FILE_PATH=

# Existing multi-market copytrade bot
COPYTRADE_MARKETS=btc
COPYTRADE_SHARES=5
COPYTRADE_TICK_SIZE=0.01
# COPYTRADE_NEG_RISK=false
# COPYTRADE_PRICE_BUFFER=0
# COPYTRADE_FIRE_AND_FORGET=true
# COPYTRADE_MIN_BALANCE_USDC=1
COPYTRADE_MAX_BUY_COUNTS_PER_SIDE=2
# COPYTRADE_WAIT_FOR_NEXT_MARKET_START=false

# Redeem script only
# CONDITION_ID=
# INDEX_SETS=

# =============================================================================
# 2. BTC 5m live common config
# =============================================================================
# These are shared defaults for btc5m:edge, btc5m:hybrid, btc5m:range-arb,
# and btc5m:market-maker. A strategy can still override any common setting with
# its own prefixed variable, e.g. EDGE_INTERVAL_MINUTES or MM_TICK_SIZE.

BTC5M_MARKET=btc
BTC5M_INTERVAL_MINUTES=5
BTC5M_TICK_SIZE=0.01
BTC5M_NEG_RISK=false
BTC5M_MIN_SECONDS_LEFT_TO_TRADE=30
BTC5M_CANCEL_SECONDS_BEFORE_END=5
BTC5M_BTC_PRICE_REFRESH_MS=1000
BTC5M_BTC_PRICE_MAX_STALE_MS=10000

# =============================================================================
# 3. BTC 5m strategy-specific config
# =============================================================================

# --- Edge Strategy: npm run btc5m:edge ---
EDGE_DRY_RUN=false                    # Set true to simulate without posting orders
EDGE_VOL_PER_INTERVAL=0.0020          # Conservative 8h sample setting
EDGE_MIN_EDGE=0.15                    # Requires fairProbability - askPrice >= 15%
EDGE_MIN_MOVE_BPS=0                   # 0 disables BTC move filter
EDGE_MIN_ELAPSED_SECONDS=0            # 0 disables cycle-start delay filter
EDGE_ORDER_USDC=3                     # USDC per signal
EDGE_MAX_USDC_PER_LEG=5               # Max USDC per UP/DOWN leg per cycle
EDGE_MAX_PRICE=0.85                   # Do not buy asks above this price
EDGE_RECORD_ENABLED=true              # Record decisions/orders for later optimization
EDGE_RECORD_FILE=data/btc5m-edge-live.csv
# Optional common overrides:
# EDGE_MARKET=btc
# EDGE_INTERVAL_MINUTES=5
# EDGE_TICK_SIZE=0.01
# EDGE_NEG_RISK=false
# EDGE_MIN_SECONDS_LEFT_TO_TRADE=30
# EDGE_CANCEL_SECONDS_BEFORE_END=5
# EDGE_BTC_PRICE_REFRESH_MS=1000
# EDGE_BTC_PRICE_MAX_STALE_MS=10000

# --- Managed-Edge Strategy: npm run btc5m:managed-edge ---
MANAGED_EDGE_DRY_RUN=true
MANAGED_EDGE_VOL_PER_INTERVAL=0.0015
MANAGED_EDGE_MIN_EDGE=0.25
MANAGED_EDGE_MIN_MOVE_BPS=0
MANAGED_EDGE_MIN_ELAPSED_SECONDS=0
MANAGED_EDGE_ORDER_USDC=3
MANAGED_EDGE_MAX_USDC_PER_LEG=5
MANAGED_EDGE_MAX_PRICE=0.85
MANAGED_EDGE_MIN_SECONDS_LEFT_TO_OPEN=60
MANAGED_EDGE_MAX_SECONDS_LEFT_TO_OPEN=240
MANAGED_EDGE_NO_CHEAP_BUY_SECONDS_LEFT=90
MANAGED_EDGE_MIN_CHEAP_PRICE=0.20
MANAGED_EDGE_MIN_ENTRY_PRICE=0.15
MANAGED_EDGE_TAKE_PROFIT_PCT=0.20
MANAGED_EDGE_TAKE_PROFIT_SELL_RATIO=0.50
MANAGED_EDGE_STOP_LOSS_PCT=0.30
MANAGED_EDGE_FORCE_EXIT_SECONDS_LEFT=30
MANAGED_EDGE_MIN_EXIT_PRICE=0.05
MANAGED_EDGE_RECORD_ENABLED=true
MANAGED_EDGE_RECORD_FILE=data/btc5m-managed-edge-live.csv
# Optional common overrides:
# MANAGED_EDGE_MARKET=btc
# MANAGED_EDGE_INTERVAL_MINUTES=5
# MANAGED_EDGE_TICK_SIZE=0.01
# MANAGED_EDGE_NEG_RISK=false
# MANAGED_EDGE_MIN_SECONDS_LEFT_TO_TRADE=30
# MANAGED_EDGE_CANCEL_SECONDS_BEFORE_END=5
# MANAGED_EDGE_BTC_PRICE_REFRESH_MS=1000
# MANAGED_EDGE_BTC_PRICE_MAX_STALE_MS=10000

# --- Adaptive-Edge Backtest Strategy ---
# Regime switching: trending edge + oscillating scalp + panic-discount buy.
ADAPTIVE_EDGE_LOOKBACK_SECONDS=60
ADAPTIVE_EDGE_MIN_HISTORY_POINTS=8
ADAPTIVE_EDGE_OSC_CROSS_COUNT=2
ADAPTIVE_EDGE_OSC_CHOPPINESS=3
ADAPTIVE_EDGE_OSC_MAX_BTC_MOVE_BPS=8
ADAPTIVE_EDGE_TREND_MIN_BTC_MOVE_BPS=10
ADAPTIVE_EDGE_TREND_MAX_CHOPPINESS=4
ADAPTIVE_EDGE_PANIC_MAX_BTC_MOVE_BPS=5
ADAPTIVE_EDGE_PANIC_MIN_DISCOUNT=0.10
ADAPTIVE_EDGE_PANIC_MIN_ASK=0.15
ADAPTIVE_EDGE_PANIC_MAX_ASK=0.45
ADAPTIVE_EDGE_UNDERVALUE_SCORE_THRESHOLD=0.20
ADAPTIVE_EDGE_MAX_REQUIRED_SIGMA=1.20
ADAPTIVE_EDGE_MOMENTUM_MIN_BPS=2
ADAPTIVE_EDGE_FAIR_MARKET_WEIGHT=0.35
ADAPTIVE_EDGE_FAIR_ASK_WEIGHT=0.20
ADAPTIVE_EDGE_PERCENTILE_WEIGHT=0.04
ADAPTIVE_EDGE_MOMENTUM_DIVERGENCE_BONUS=0.04
ADAPTIVE_EDGE_PANIC_DISCOUNT_BONUS=0.03
ADAPTIVE_EDGE_REQUIRED_SIGMA_PENALTY=0.10
ADAPTIVE_EDGE_LATE_TIME_PENALTY=0.05
ADAPTIVE_EDGE_SCALP_PROFIT_PRICE=0.10
ADAPTIVE_EDGE_SCALP_PROFIT_PCT=0.25

# --- Trend-Pullback Strategy: npm run btc5m:trend-pullback ---
# After either leg reaches the trigger, keep a lower BUY limit open until the cycle ends.
TREND_PULLBACK_DRY_RUN=true
TREND_PULLBACK_TRIGGER_PRICE=0.85
TREND_PULLBACK_ENTRY_PRICE=0.80
TREND_PULLBACK_ORDER_USDC=5
TREND_PULLBACK_MAX_USDC_PER_LEG=5
TREND_PULLBACK_MIN_SECONDS_LEFT_TO_TRIGGER=30
TREND_PULLBACK_TRIGGER_CONFIRM_SECONDS=0
TREND_PULLBACK_MAX_ORDER_AGE_SECONDS=0
TREND_PULLBACK_MAX_BTC_REVERSAL_BPS=8
TREND_PULLBACK_EVALUATION_INTERVAL_MS=1000
TREND_PULLBACK_ORDER_POLL_INTERVAL_MS=2000
TREND_PULLBACK_RECORD_ENABLED=true
TREND_PULLBACK_RECORD_FILE=data/btc5m-trend-pullback-live.csv
# Optional BTC source override, separated by | or comma:
# TREND_PULLBACK_BTC_PRICE_URLS=https://api.exchange.coinbase.com/products/BTC-USD/ticker|https://api.kraken.com/0/public/Ticker?pair=XBTUSD
# Optional common overrides:
# TREND_PULLBACK_MARKET=btc
# TREND_PULLBACK_INTERVAL_MINUTES=5
# TREND_PULLBACK_TICK_SIZE=0.01
# TREND_PULLBACK_NEG_RISK=false
# TREND_PULLBACK_CANCEL_SECONDS_BEFORE_END=5
# TREND_PULLBACK_BTC_PRICE_REFRESH_MS=1000
# TREND_PULLBACK_BTC_PRICE_MAX_STALE_MS=10000

# --- Hybrid Strategy: npm run btc5m:hybrid ---
HYBRID_DRY_RUN=true
HYBRID_VOL_PER_INTERVAL=0.0006
HYBRID_MIN_EDGE=0.10
HYBRID_EDGE_MIN_MOVE_BPS=0
HYBRID_EDGE_MIN_ELAPSED_SECONDS=0
HYBRID_ORDER_USDC=3
HYBRID_MAX_USDC_PER_LEG=5
HYBRID_MAX_PRICE=0.85
HYBRID_RANGE_PRICE_X=0.35
HYBRID_RANGE_USDC_PER_LEG=3
HYBRID_LOOKBACK_SECONDS=60
HYBRID_OSC_THRESHOLD=2
HYBRID_RANGE_THRESHOLD=0.25
HYBRID_TREND_THRESHOLD=0.10
# Optional common overrides:
# HYBRID_MARKET=btc
# HYBRID_INTERVAL_MINUTES=5
# HYBRID_TICK_SIZE=0.01
# HYBRID_NEG_RISK=false
# HYBRID_MIN_SECONDS_LEFT_TO_TRADE=30
# HYBRID_CANCEL_SECONDS_BEFORE_END=5
# HYBRID_BTC_PRICE_REFRESH_MS=1000
# HYBRID_BTC_PRICE_MAX_STALE_MS=10000

# --- Range-Arb Strategy: npm run btc5m:range-arb ---
RANGE_ARB_DRY_RUN=true
RANGE_ARB_PRICE_X=0.40                # Must be below 0.5
RANGE_ARB_USDC_PER_LEG=5
RANGE_ARB_MIN_SECONDS_LEFT_TO_OPEN=60
RANGE_ARB_REQUIRE_AMPLITUDE=false
RANGE_ARB_AMPLITUDE_LOOKBACK_SECONDS=120
RANGE_ARB_AMPLITUDE_BUFFER=0.03
# Optional common overrides:
# RANGE_ARB_MARKET=btc
# RANGE_ARB_INTERVAL_MINUTES=5
# RANGE_ARB_TICK_SIZE=0.01
# RANGE_ARB_NEG_RISK=false
# RANGE_ARB_CANCEL_SECONDS_BEFORE_END=8

# --- Market-Maker Strategy: npm run btc5m:market-maker ---
MM_DRY_RUN=true
MM_QUOTE_SHARES=5
MM_MAX_USDC_PER_LEG=0                 # 0 = unlimited per leg
MM_MAX_INVENTORY_SHARES=30
MM_QUOTE_SPREAD=0.06
MM_MIN_LOCKED_EDGE=0.02
MM_INVENTORY_SKEW_PER_SHARE=0.002
MM_REQUOTE_THRESHOLD=0.01
MM_MIN_SECONDS_LEFT_TO_QUOTE=45
MM_QUOTE_INTERVAL_MS=1000
MM_POLL_INTERVAL_MS=2000
MM_ENABLE_SELL_EXCESS=true
# Optional common overrides:
# MM_MARKET=btc
# MM_INTERVAL_MINUTES=5
# MM_TICK_SIZE=0.01
# MM_NEG_RISK=false
# MM_CANCEL_SECONDS_BEFORE_END=8

# =============================================================================
# 4. Research tools: backtest and collector
# =============================================================================

# --- Backtest: npm run backtest:btc5m ---
# Supported strategies: edge, managed-edge, adaptive-edge, trend-pullback,
# range-arb, market-maker, hybrid
# and btc5m:* aliases.
BACKTEST_STRATEGY=edge
BACKTEST_CSV=
BACKTEST_TRADES_OUT=logs/backtest-btc5m-trades.csv
BACKTEST_INTERVAL_MINUTES=5
BACKTEST_VOL_PER_INTERVAL=0.0015
BACKTEST_MIN_EDGE=0.03
BACKTEST_EDGE_MIN_MOVE_BPS=0
BACKTEST_EDGE_MIN_ELAPSED_SECONDS=0
BACKTEST_ORDER_USDC=5
BACKTEST_MAX_USDC_PER_LEG=10
BACKTEST_MIN_SECONDS_LEFT=10
BACKTEST_MAX_PRICE=0.98

# --- History collector: npm run collect:btc5m-history ---
# Set duration to 0 to run forever.
COLLECT_MARKET=btc
COLLECT_INTERVAL_MINUTES=5
COLLECT_DURATION_MINUTES=60
COLLECT_SAMPLE_MS=1000
COLLECT_OUT_DIR=data
COLLECT_OUT_FILE=btc5m-history.csv
# Polymarket-only by default. Enable only if you want external BTC/open prices in CSV.
COLLECT_BTC_PRICE_ENABLED=false
# Multiple external BTC price sources, tried left-to-right when enabled. Separate with |.
COLLECT_BTC_PRICE_URLS=https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT|https://api.exchange.coinbase.com/products/BTC-USD/ticker|https://api.kraken.com/0/public/Ticker?pair=XBTUSD|https://www.okx.com/api/v5/market/ticker?instId=BTC-USDT
