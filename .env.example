# Copy to .env and fill in values. Only these vars are read by src/config/index.ts

# --- Required (bot & redeem) ---
WALLET_PRIVATE_KEY=

# --- Wallet (SIG_TYPE: eoa | proxy | gnosis) ---
SIG_TYPE=eoa
PROXY_WALLET_ADDRESS=

# --- General ---
# DEBUG=false
# CHAIN_ID=137
# CLOB_API_URL=https://clob.polymarket.com
# NEG_RISK=false

# --- Bot runner ---
# BOT_MIN_USDC_BALANCE=1
# COPYTRADE_WAIT_FOR_NEXT_MARKET_START=false

# --- Logging ---
# LOG_DIR=logs
# LOG_FILE_PREFIX=bot
# LOG_FILE_PATH=

# --- Copytrade ---
COPYTRADE_MARKETS=btc
COPYTRADE_SHARES=5
COPYTRADE_TICK_SIZE=0.01
# COPYTRADE_NEG_RISK=false
# COPYTRADE_PRICE_BUFFER=0
# COPYTRADE_FIRE_AND_FORGET=true
# COPYTRADE_MIN_BALANCE_USDC=1
COPYTRADE_MAX_BUY_COUNTS_PER_SIDE=2

# --- Redeem script only ---
# CONDITION_ID=
# INDEX_SETS=

# --- BTC 5m range arbitrage ---
# Dry-run by default. Set false only after confirming parameters and wallet setup.
RANGE_ARB_DRY_RUN=true
RANGE_ARB_MARKET=btc
RANGE_ARB_INTERVAL_MINUTES=5
RANGE_ARB_PRICE_X=0.40
RANGE_ARB_USDC_PER_LEG=5
RANGE_ARB_TICK_SIZE=0.01
# Keep this below 0.5; profit after both legs fill is y * (1 / x - 2).
# Optional safety controls:
# RANGE_ARB_MIN_SECONDS_LEFT_TO_OPEN=60
# RANGE_ARB_CANCEL_SECONDS_BEFORE_END=8
# RANGE_ARB_REQUIRE_AMPLITUDE=false
# RANGE_ARB_AMPLITUDE_LOOKBACK_SECONDS=120
# RANGE_ARB_AMPLITUDE_BUFFER=0.03

# --- BTC 5m market maker ---
# Dry-run by default. Set false only after watching dry-run logs.
MM_DRY_RUN=true
MM_MARKET=btc
MM_INTERVAL_MINUTES=5
MM_QUOTE_SHARES=5
# Max USDC spent buying each leg per 5m round. 0 = unlimited.
MM_MAX_USDC_PER_LEG=0
MM_MAX_INVENTORY_SHARES=30
MM_QUOTE_SPREAD=0.06
MM_MIN_LOCKED_EDGE=0.02
MM_INVENTORY_SKEW_PER_SHARE=0.002
MM_REQUOTE_THRESHOLD=0.01
MM_TICK_SIZE=0.01
# MM_NEG_RISK=false
MM_MIN_SECONDS_LEFT_TO_QUOTE=45
MM_CANCEL_SECONDS_BEFORE_END=8
MM_QUOTE_INTERVAL_MS=1000
MM_POLL_INTERVAL_MS=2000
MM_ENABLE_SELL_EXCESS=true

# --- BTC 5m edge backtest ---
# CSV columns: timestamp,btc_price,up_ask,down_ask
# Optional columns: slug,open_price
# Supported: edge, btc5m:edge, range-arb, market-maker, btc5m:range-arb, btc5m:market-maker
BACKTEST_STRATEGY=edge
BACKTEST_CSV=
BACKTEST_TRADES_OUT=logs/backtest-btc5m-trades.csv
BACKTEST_INTERVAL_MINUTES=5
BACKTEST_VOL_PER_INTERVAL=0.0015
BACKTEST_MIN_EDGE=0.03
BACKTEST_ORDER_USDC=5
BACKTEST_MAX_USDC_PER_LEG=10
BACKTEST_MIN_SECONDS_LEFT=10
BACKTEST_MAX_PRICE=0.98

# --- BTC 5m history collector ---
# Run with: npm run collect:btc5m-history
# Set duration to 0 to run forever.
COLLECT_MARKET=btc
COLLECT_INTERVAL_MINUTES=5
COLLECT_DURATION_MINUTES=60
COLLECT_SAMPLE_MS=1000
COLLECT_OUT_DIR=data
COLLECT_OUT_FILE=btc5m-history.csv
# Polymarket-only by default. Enable only if you want external BTC/open prices in CSV.
COLLECT_BTC_PRICE_ENABLED=false
# Multiple external BTC price sources, tried left-to-right when enabled. Separate with |.
COLLECT_BTC_PRICE_URLS=https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT|https://api.exchange.coinbase.com/products/BTC-USD/ticker|https://api.kraken.com/0/public/Ticker?pair=XBTUSD|https://www.okx.com/api/v5/market/ticker?instId=BTC-USDT

# --- BTC 5m Edge Strategy ---
EDGE_DRY_RUN=false                    # 先观察再实盘
EDGE_VOL_PER_INTERVAL=0.0008         # 回测最优：降低波动率估计
EDGE_MIN_EDGE=0.05                   # 平衡胜率和交易频率
EDGE_ORDER_USDC=3                    # 每笔 $3
EDGE_MAX_USDC_PER_LEG=5              # 每方向最多 $5/周期（余额要求: 5*2=$10）
EDGE_MAX_PRICE=0.85                  # 不买太贵的
EDGE_MIN_SECONDS_LEFT_TO_TRADE=30    # 最后30秒不再开仓
EDGE_CANCEL_SECONDS_BEFORE_END=5     # 最后5秒撤单

